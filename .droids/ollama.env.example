# Example environment variables for running the Ollama-Droid agent runtime.
# Copy this file to .droids/ollama.env, fill in your real values, and source it
# at run time. NEVER commit the real .droids/ollama.env file.

OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=codellama:7b
OLLAMA_API_KEY=your-ollama-api-key

# Optional: absolute paths to Droid config files for DOER and REVIEWER roles.
# DROID_DOER_CONFIG=/workspace/.droids/ollama-droid.md
# DROID_REVIEWER_CONFIG=/workspace/.droids/ollama-droid.md
