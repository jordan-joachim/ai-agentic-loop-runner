# Example environment configuration for ai-agentic-loop-runner.
# Copy this file to .env and fill in real values. Never commit .env.

# Harness runtime selection: mock | droid | ollama-droid | kilo
HARNESS_AGENT_RUNTIME=mock

# Default prompt file, relative to repo root
HARNESS_PROMPT_FILE=prompts/fvt-coverage.md

# Workspace directory, relative to repo root
HARNESS_WORKSPACE_DIR=workspace

# Rules file, relative to repo root
HARNESS_RULES_FILE=rules.yaml

# Ollama credentials (only needed for ollama-droid)
OLLAMA_HOST=
OLLAMA_MODELS=
OLLAMA_API_KEY=

# Kilo credentials (only needed for kilo)
KILO_API_KEY=
# Default model is the free Kilo Auto tier (kilo-auto/free).
# Optional: override provider and model, e.g. anthropic/claude-sonnet-4-20250514
KILO_PROVIDER=
KILO_MODEL=

# IBM Cloud Code Engine credentials (only needed for codeengine phase)
IBMCLOUD_API_KEY=
COS_BUCKET=
COS_ENDPOINT=
CE_PROJECT_NAME=agentic-loop-ce-project
CE_JOB_NAME=agentic-loop-harness-job

# Optional GitHub PR automation
GITHUB_TOKEN=
