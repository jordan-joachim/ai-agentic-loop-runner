#!/usr/bin/env node

/**
 * bin/harness — generic harness CLI entry point for the runner package.
 *
 * The runner package consumes the generic @agentic-loop/harness package and
 * re-exposes its bin/harness entrypoint in its own bin/ directory. The
 * Containerfile copies this script into the image so the generic
 * `node bin/harness --workspace /workspace` ENTRYPOINT works.
 *
 * Usage:
 *   bin/harness --workspace <path>
 */

import { spawn } from 'node:child_process';
import { fileURLToPath } from 'node:url';
import { dirname, resolve } from 'node:path';

const __dirname = dirname(fileURLToPath(import.meta.url));

// Resolve the harness CLI inside the local node_modules. Until the harness is
// published to npm, link it locally with `npm link @agentic-loop/harness`.
const harnessPackageRoot = resolve(__dirname, '..', 'node_modules', '@agentic-loop', 'harness');
const harnessBin = resolve(harnessPackageRoot, 'bin', 'harness');

const child = spawn(
  process.execPath,
  [harnessBin, ...process.argv.slice(2)],
  {
    stdio: 'inherit',
    env: process.env,
  },
);

child.on('exit', (code) => {
  process.exit(code ?? 1);
});
